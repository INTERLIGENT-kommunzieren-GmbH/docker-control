#!/usr/bin/env bash

IMAGE="ghcr.io/interligent-kommunzieren-gmbh/docker-plugin:latest"
PROJECT_DIR=$(pwd)
PARAMETER=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        docker-cli-plugin-metadata)
            docker run --rm "$IMAGE" docker-cli-plugin-metadata
            exit
            ;;
        --dir|-d)
            shift
            PROJECT_DIR=$(realpath "$1")
            shift
            ;;
        *)
            PARAMETER+=("$1")
            shift
    esac
done

# Platform detection and network binding strategy
detect_platform() {
    local platform=""
    local bind_ip="localhost"

    # Check if running on macOS
    if [[ "$(uname)" == "Darwin" ]]; then
        platform="macos"
        bind_ip="localhost"
        echo "Detected macOS platform" >&2
    # Check if running on Linux
    elif [[ "$(uname)" == "Linux" ]]; then
        # Check if running in WSL
        if grep -qi microsoft /proc/version 2>/dev/null || grep -qi wsl /proc/version 2>/dev/null; then
            platform="wsl"
            bind_ip="localhost"
            echo "Detected WSL platform" >&2
        # Check if Docker Desktop is running using docker info command
        elif docker info >/dev/null 2>&1; then
            local docker_info_output
            docker_info_output=$(docker info 2>/dev/null)

            # Look for Docker Desktop indicators in docker info output
            if echo "$docker_info_output" | grep -qi "docker desktop\|desktop.*context\|desktop.*engine\|com\.docker\.desktop" || \
               echo "$docker_info_output" | grep -qi "storage driver.*desktop\|operating system.*docker desktop" || \
               echo "$docker_info_output" | grep -qi "server version.*desktop\|context.*desktop" || \
               echo "$docker_info_output" | grep -qi "docker\.sock.*desktop\|docker.*desktop.*daemon"; then
                platform="docker-desktop"
                bind_ip="localhost"
                echo "Detected Docker Desktop environment via docker info" >&2
            else
                # Additional check: look for typical Docker Desktop characteristics
                # Docker Desktop often runs with specific storage drivers and configurations
                local is_desktop=false

                # Check for Docker Desktop on macOS/Windows indicators
                if echo "$docker_info_output" | grep -qi "operating system.*docker desktop\|server.*docker desktop"; then
                    is_desktop=true
                # Check for overlay2 with desktop-specific paths or configurations
                elif echo "$docker_info_output" | grep -qi "docker root dir.*docker.*desktop\|data root.*docker.*desktop"; then
                    is_desktop=true
                # Check for desktop-specific runtime or storage configurations
                elif echo "$docker_info_output" | grep -qi "containerd.*desktop\|runc.*desktop"; then
                    is_desktop=true
                fi

                if [[ "$is_desktop" == "true" ]]; then
                    platform="docker-desktop"
                    bind_ip="localhost"
                    echo "Detected Docker Desktop environment via configuration analysis" >&2
                else
                    # Native Linux - try to detect docker0 bridge IP
                    platform="native-linux"
                    # Try to get docker0 interface IP
                    local docker0_ip=""
                    if command -v ip >/dev/null 2>&1; then
                        docker0_ip=$(ip addr show docker0 2>/dev/null | grep -oP 'inet \K[\d.]+' | head -1)
                    elif command -v ifconfig >/dev/null 2>&1; then
                        docker0_ip=$(ifconfig docker0 2>/dev/null | grep -oP 'inet \K[\d.]+' | head -1)
                    fi

                    if [[ -n "$docker0_ip" && "$docker0_ip" != "127.0.0.1" ]]; then
                        bind_ip="$docker0_ip"
                        echo "Detected native Linux with docker0 IP: $docker0_ip" >&2
                    else
                        # Fallback to localhost if docker0 IP detection fails
                        bind_ip="localhost"
                        echo "Detected native Linux but failed to get docker0 IP, falling back to localhost" >&2
                    fi
                fi
            fi
        # Fallback if docker info fails - assume native Linux
        else
            platform="native-linux"
            # Try to get docker0 interface IP
            local docker0_ip=""
            if command -v ip >/dev/null 2>&1; then
                docker0_ip=$(ip addr show docker0 2>/dev/null | grep -oP 'inet \K[\d.]+' | head -1)
            elif command -v ifconfig >/dev/null 2>&1; then
                docker0_ip=$(ifconfig docker0 2>/dev/null | grep -oP 'inet \K[\d.]+' | head -1)
            fi

            if [[ -n "$docker0_ip" && "$docker0_ip" != "127.0.0.1" ]]; then
                bind_ip="$docker0_ip"
                echo "Detected native Linux (docker info failed) with docker0 IP: $docker0_ip" >&2
            else
                # Fallback to localhost if docker0 IP detection fails
                bind_ip="localhost"
                echo "Detected native Linux (docker info failed) but failed to get docker0 IP, falling back to localhost" >&2
            fi
        fi
    else
        # Unknown platform, default to localhost
        platform="unknown"
        bind_ip="localhost"
        echo "Unknown platform detected, using localhost" >&2
    fi

    echo "$platform:$bind_ip"
}

# Platform detection variables (will be set when needed)
PLATFORM=""
BIND_IP=""
PLATFORM_DETECTED=false

# Function to get platform info with caching
get_platform_info() {
    if [[ "$PLATFORM_DETECTED" == "false" ]]; then
        local platform_info
        platform_info=$(detect_platform)
        PLATFORM=$(echo "$platform_info" | cut -d: -f1)
        BIND_IP=$(echo "$platform_info" | cut -d: -f2)
        PLATFORM_DETECTED=true
    fi
}

if ! command -v nc &> /dev/null; then
    echo "netcat (nc) not found in path"
    exit 1
fi

if ! command -v socat &> /dev/null; then
    echo "socat not found in path"
    exit 1
fi

# Check SSH agent forwarding - only detect platform if socket binding is needed
if ! nc -zv localhost 2222 > /dev/null 2>&1; then
    if [[ -z "$SSH_AUTH_SOCK" ]]; then
        echo "SSH agent seems to not be running."
        exit 1
    fi

    # Get platform info only when needed for socket binding
    get_platform_info

    echo "Starting SSH agent forwarding socket on $BIND_IP:2222"
    socat TCP-LISTEN:2222,bind="$BIND_IP",reuseaddr,fork UNIX-CONNECT:"$SSH_AUTH_SOCK" > /dev/null 2>&1 &
    # shellcheck disable=SC2181
    if [[ $? -ne 0 ]]; then
        echo "ERROR: Failed to start SSH agent forwarding on $BIND_IP:2222"
        if [[ "$BIND_IP" != "localhost" ]]; then
            echo "Falling back to localhost binding"
            BIND_IP="localhost"
            socat TCP-LISTEN:2222,bind=localhost,reuseaddr,fork UNIX-CONNECT:"$SSH_AUTH_SOCK" > /dev/null 2>&1 &
        else
            exit 1
        fi
    fi
    sleep 1

    containers=$(docker ps -q --filter "label=com.interligent.dockerplugin.service=php")
    if [ -n "$containers" ]; then
        echo "restarting php containers to connect to new ssh agent port"
        # shellcheck disable=SC2086
        docker restart $containers
    fi
fi

# Function to configure Docker options based on platform and binding strategy
configure_docker_options() {
    # Ensure platform info is available
    get_platform_info

    if [[ "$PLATFORM" == "native-linux" && "$BIND_IP" != "localhost" ]]; then
        # For native Linux with docker0 binding, use the detected IP
        SSH_AUTH_HOST="$BIND_IP"
        DOCKER_HOST_IP="$BIND_IP"
    else
        # For all other platforms, use host.docker.internal
        SSH_AUTH_HOST="host.docker.internal"
        DOCKER_HOST_IP="host.docker.internal"
    fi

    OPTS=(
        --rm -it
        --network host
        --add-host host.docker.internal:host-gateway
        -u "$(id -u):$(id -g)"
        -e UID="$(id -u)"
        -e GID="$(id -g)"
        -e SSH_AUTH_PORT="$SSH_AUTH_HOST:2222"
        -v "$PROJECT_DIR":"$PROJECT_DIR"
        -w "$PROJECT_DIR"
        -v "$HOME/.docker/cli-plugins":"/cli-plugins"
        -v "$HOME/.ik/docker-plugin-mounts":"/docker-plugin-mounts"
        -e PLUGIN_MOUNTS_DIR="$HOME/.ik/docker-plugin-mounts"
        -e DOCKER_HOST=tcp://"$DOCKER_HOST_IP":2375
    )
}

# Check Docker socket forwarding - only detect platform if socket binding is needed
if ! nc -zv localhost 2375 > /dev/null 2>&1; then
    # Get platform info only when needed for socket binding
    get_platform_info

    DOCKER_SOCK="$(docker context inspect --format '{{(index .Endpoints.docker.Host)}}' | sed -e 's|^unix://||')"
    echo "Starting docker forwarding socket on $BIND_IP:2375"
    socat TCP-LISTEN:2375,bind="$BIND_IP",reuseaddr,fork UNIX-CONNECT:"$DOCKER_SOCK" > /dev/null 2>&1 &
    # shellcheck disable=SC2181
    if [[ $? -ne 0 ]]; then
        echo "ERROR: Failed to start Docker forwarding on $BIND_IP:2375"
        if [[ "$BIND_IP" != "localhost" ]]; then
            echo "Falling back to localhost binding"
            BIND_IP="localhost"
            socat TCP-LISTEN:2375,bind=localhost,reuseaddr,fork UNIX-CONNECT:"$DOCKER_SOCK" > /dev/null 2>&1 &
        else
            exit 1
        fi
    fi
    sleep 1
fi

# Configure Docker options and run container
configure_docker_options
docker run "${OPTS[@]}" "$IMAGE" "${PARAMETER[@]}"