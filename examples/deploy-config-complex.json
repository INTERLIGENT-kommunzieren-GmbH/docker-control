{
  "version": "1.0",
  "environments": {
    "production": {
      "user": "deploy",
      "domain": "production.example.com",
      "serviceRoot": "/var/www/html",
      "description": "Production environment - stable releases only",
      "tags": ["production", "critical", "monitored"],
      "teamsWebhookUrl": "https://outlook.office.com/webhook/12345678-1234-1234-1234-123456789012@12345678-1234-1234-1234-123456789012/IncomingWebhook/abcdef1234567890abcdef1234567890/12345678-1234-1234-1234-123456789012",
      "sharedDirectories": ["uploads", "cache", "logs", "storage/temp"],
      "sharedFiles": ["config/database.json", "storage/app.log", ".env.local"],
      "copsIntegration": true
    },
    "staging": {
      "user": "deploy",
      "domain": "staging.projects.interligent.com",
      "serviceRoot": "/var/www/html",
      "description": "Staging environment for testing and validation",
      "tags": ["staging", "testing"],
      "teamsWebhookUrl": "https://tenant.webhook.office.com/webhookb2/87654321-4321-4321-4321-210987654321@87654321-4321-4321-4321-210987654321/IncomingWebhook/fedcba0987654321fedcba0987654321/87654321-4321-4321-4321-210987654321",
      "sharedDirectories": ["uploads", "cache", "logs"],
      "sharedFiles": ["config/database.json"],
      "copsIntegration": false
    },
    "development": {
      "user": "dev",
      "domain": "dev.projects.interligent.com",
      "serviceRoot": "/opt/app",
      "description": "Development environment for feature testing",
      "tags": ["development", "unstable"],
      "sharedDirectories": ["uploads", "cache"],
      "sharedFiles": ["config/database.json"]
    },
    "qa": {
      "user": "qa",
      "domain": "qa.example.com",
      "serviceRoot": "/var/www/html",
      "description": "Quality assurance environment",
      "tags": ["qa", "testing", "automated"],
      "sharedDirectories": ["uploads", "cache", "logs"],
      "sharedFiles": ["config/database.json", "storage/app.log"]
    }
  },
  "environmentOrder": ["development", "qa", "staging", "production"],
  "defaults": {
    "serviceRoot": "/var/www/html",
    "domainSuffix": ".projects.interligent.com"
  },
  "metadata": {
    "createdAt": "2025-01-08T10:30:00Z",
    "lastModified": "2025-01-08T11:45:00Z",
    "createdBy": "docker-control-plugin"
  }
}
